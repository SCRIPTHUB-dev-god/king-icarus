-- Tambahkan fungsi pembantu ini di bagian atas (di luar loop) agar rapi
local function ExecuteScript(input)
    local success, err = pcall(function()
        -- Cek apakah input adalah URL (dimulai dengan http)
        if input:sub(1, 4) == "http" and not input:find(" ") then
            loadstring(game:HttpGet(input))()
        else
            -- Jika bukan URL, jalankan sebagai kode langsung
            loadstring(input)()
        end
    end)
    if not success then 
        warn("Execute Error: " .. tostring(err)) 
    end
end


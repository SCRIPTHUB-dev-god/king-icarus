local list1 = {
    {name = "speed hub x", url = "https://raw.githubusercontent.com/AhmadV99/Speed-Hub-X/main/Speed%20Hub%20X.lua", auto_execute = false},
    {name = "chiyo hub", url = "https://raw.githubusercontent.com/kaisenlmao/loader/refs/heads/main/chiyo.lua", auto_execute = false},
    {name = "solix hub", url = "https://raw.githubusercontent.com/bao8jl/solixhub/main/loader", auto_execute = false},
    {name = "lunor hub", url = "https://lunor.dev/loader", auto_execute = false},
    {name = "lumin hub", url = "http://luminon.top/loader.lua", auto_execute = false},
}

for _, item in ipairs(list1) do
    if SavedData[item.name] ~= nil then
        item.auto_execute = SavedData[item.name]
    end

    LeftGroupBox:AddLabel(item.name)

    LeftGroupBox:AddButton({
        Text = "Execute",
        Func = function()
            local success, err = pcall(function() loadstring(game:HttpGet(item.url))() end)
            if not success then warn(err) end
        end
    })

    local id = "Auto_".. item.name:gsub("%W+", "")
    local toggle = LeftGroupBox:AddToggle(id, {
        Text = "Auto Execute",
        Default = item.auto_execute,
    })

    toggle:OnChanged(function(state)
        item.auto_execute = state
        SaveConfig(item.name, state)
        print(item.name.. " auto save: ".. tostring(state))
    end)

    if item.auto_execute then
        task.spawn(function()
            pcall(function() loadstring(game:HttpGet(item.url))() end)
        end)
    end

    LeftGroupBox:AddDivider()
end

